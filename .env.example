
DB_URL=jdbc:mysql://localhost:3306/dailyyam?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=changeme

# openssl rand -base64 64 로 직접 생성해서 사용
JWT_SECRET=changeme

# 업로드 파일 저장 디렉터리 (기본: ./uploads)
UPLOAD_DIR=uploads

# SSAFY GMS API 키 — Anthropic(chat/vision) + OpenAI(임베딩) 프록시 공용
GMS_KEY=

# 사진 분석 모델 선택: anthropic(Claude, 기본) | gemini. 미설정 시 anthropic.
VISION_PROVIDER=anthropic

# Redis(Stack) 접속 (로컬: localhost, docker-compose: redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# 식약처 식품영양성분DB 인증키 (공공데이터포털 Encoding 키). 미설정 시 로컬 foods 검색만 동작.
MFDS_SERVICE_KEY=

# CORS 허용 Origin (콤마 구분). 기본 *(모두 허용). 운영 예: https://myapp.com,http://localhost:5173
CORS_ALLOWED_ORIGINS=*
